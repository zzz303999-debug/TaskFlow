<!--pages/calendar/calendar.wxml-->
<view class="container">
  <view class="header">
    <text class="title">日程安排</text>
  </view>

  <!-- 日历头部 -->
  <view class="calendar-header card">
    <view class="calendar-nav">
      <text class="nav-btn" bindtap="prevMonth">‹</text>
      <text class="current-month">{{currentMonth}}</text>
      <text class="nav-btn" bindtap="nextMonth">›</text>
    </view>
    
    <view class="weekdays">
      <text class="weekday" wx:for="{{weekdays}}" wx:key="*this" wx:for-item="day">{{day}}</text>
    </view>
    
    <view class="days-grid">
      <view 
        class="day-cell {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.hasEvent ? 'has-event' : ''}}"
        wx:for="{{days}}" 
        wx:key="date"
        bindtap="selectDay"
        data-date="{{item.date}}"
      >
        <text class="day-num">{{item.day}}</text>
        <view class="event-dot" wx:if="{{item.hasEvent}}"></view>
      </view>
    </view>
  </view>

  <!-- 选中日期的事件 -->
  <view class="events-section">
    <view class="section-title">{{selectedDate}} 的安排</view>
    
    <view class="card" wx:if="{{events.length === 0}}">
      <view class="empty-state">
        <text class="empty-icon"></text>
        <text class="empty-text">这天还没有安排</text>
      </view>
    </view>

    <view class="card" wx:else>
      <view class="event-item" wx:for="{{events}}" wx:key="id">
        <view class="event-time">
          <text class="time">{{item.time}}</text>
        </view>
        <view class="event-info">
          <text class="event-title">{{item.title}}</text>
          <text class="event-location" wx:if="{{item.location}}">📍 {{item.location}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 本周概览 -->
  <view class="week-overview card">
    <view class="section-title">本周概览</view>
    <view class="week-stats">
      <view class="stat-item">
        <text class="stat-num">{{weekStats.total}}</text>
        <text class="stat-label">总任务</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{weekStats.completed}}</text>
        <text class="stat-label">已完成</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{weekStats.pending}}</text>
        <text class="stat-label">待完成</text>
      </view>
    </view>
  </view>
</view>
