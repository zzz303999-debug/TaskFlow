<!--pages/detail/detail.wxml-->
<view class="container">
  <view class="header">
    <text class="title">{{title}}</text>
  </view>

  <!-- 任务状态卡片 -->
  <view class="status-card card">
    <view class="status-row">
      <text class="status-label">状态</text>
      <view class="status-toggle">
        <view class="toggle-wrapper" bindtap="toggleComplete">
          <view class="toggle-track {{done ? 'active' : ''}}">
            <view class="toggle-thumb {{done ? 'active' : ''}}"></view>
          </view>
        </view>
        <text class="status-text {{done ? 'done' : 'pending'}}">{{done ? '已完成' : '进行中'}}</text>
      </view>
    </view>
  </view>

  <!-- 任务信息卡片 -->
  <view class="card">
    <view class="info-item">
      <view class="info-label">
        <image class="icon" src="/images/priority.png" mode="aspectFit"></image>
        <text>优先级</text>
      </view>
      <text class="info-value high">高</text>
    </view>
    
    <view class="info-item">
      <view class="info-label">
        <image class="icon" src="/images/deadline.png" mode="aspectFit"></image>
        <text>截止时间</text>
      </view>
      <text class="info-value">{{deadline}}</text>
    </view>
    
    <view class="info-item">
      <view class="info-label">
        <image class="icon" src="/images/note.png" mode="aspectFit"></image>
        <text>备注</text>
      </view>
      <text class="info-value note">{{note}}</text>
    </view>

    <view class="info-item">
      <view class="info-label">
        <image class="icon" src="/images/tag.png" mode="aspectFit"></image>
        <text>标签</text>
      </view>
      <view class="tags">
        <text class="tag">学习</text>
        <text class="tag">重要</text>
      </view>
    </view>
  </view>

  <!-- 子任务 -->
  <view class="card">
    <view class="section-title">子任务</view>
    <view class="subtask" wx:for="{{subtasks}}" wx:key="id">
      <view class="subtask-checkbox {{item.done ? 'checked' : ''}}"></view>
      <text class="subtask-title {{item.done ? 'done' : ''}}">{{item.title}}</text>
    </view>
    <view class="add-subtask" bindtap="addSubtask">
      <text class="add-icon">+</text>
      <text>添加子任务</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <view class="btn complete-btn" bindtap="toggleComplete">
      <text>{{done ? '标记为未完成' : '完成任务'}}</text>
    </view>
    <view class="btn delete-btn" bindtap="deleteTask">
      <text>删除</text>
    </view>
  </view>
</view>

<!-- Toast -->
<view class="toast {{toastShow ? 'show' : ''}}">{{toastText}}</view>
